# ============================================================
# Crypto Staking Monitor — Configuration
# Copy to .env and fill in real values.
# ============================================================

# --- Exchange (for price data only, no trading) ---
EXCHANGE_ID=tokocrypto

# --- Staking positions ---
# SOL staking
STAKING_SOL_AMOUNT=500000          # IDR value staked
STAKING_SOL_ENTRY_PRICE=170.00     # SOL price when you bought (USD)
STAKING_SOL_APY=0.0571             # 5.71%

# USDT staking
STAKING_USDT_AMOUNT=500000         # IDR value staked
STAKING_USDT_APY=0.10              # 10%

# --- Alert thresholds ---
DCA_DIP_PCT=0.05                   # Alert when SOL drops 5% from entry
REBALANCE_THRESHOLD_PCT=0.10       # Alert when portfolio >10% off target
TARGET_SOL_PCT=0.50                # 50% target allocation for SOL

# --- Rate ---
IDR_USD_RATE=16500                 # IDR per 1 USD

# --- Telegram (optional, uses Hermes delivery if empty) ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Platform label ---
PLATFORM=tokocrypto
