# ============================================================
# Crypto Staking Monitor — Configuration
# Copy to .env and fill in real values.
# ============================================================

# --- Exchange ---
EXCHANGE_ID=tokocrypto
# Only needed if TRADING_ENABLED=true
EXCHANGE_API_KEY=
EXCHANGE_SECRET=

# --- Trading Safety ---
TRADING_ENABLED=false        # true = can place real orders
DRY_RUN=true                 # true = paper trade (no real orders)
MAX_TRADE_IDR=500000         # max IDR per single trade

# --- Staking positions ---
STAKING_SOL_AMOUNT=500000    # IDR value staked in SOL
STAKING_SOL_ENTRY_PRICE=81.14  # SOL price when bought (USD)
STAKING_SOL_APY=0.0571       # 5.71%

STAKING_USDT_AMOUNT=500000   # IDR value staked in USDT
STAKING_USDT_APY=0.10        # 10%

# --- Auto-Compound ---
AUTO_COMPOUND=true           # auto restake rewards
COMPOUND_MIN_IDR=10000       # min reward before compound

# --- DCA ---
DCA_ENABLED=true
DCA_DIP_PCT=0.05             # alert on 5% dip from entry
DCA_SUGGEST_MIN=50000        # min DCA suggestion (IDR)
DCA_SUGGEST_MAX=200000       # max DCA suggestion (IDR)
DCA_AUTO_BUY=false           # true = auto-buy on dip

# --- Rebalance ---
REBALANCE_ENABLED=true
REBALANCE_THRESHOLD_PCT=0.10 # alert if >10% off target
REBALANCE_INTERVAL_MONTHS=3  # check quarterly
REBALANCE_AUTO_EXECUTE=false # true = auto buy/sell to rebalance
TARGET_SOL_PCT=0.50          # 50% SOL / 50% USDT

# --- Rate ---
IDR_USD_RATE=16500

# --- Telegram (optional — Hermes cron handles delivery) ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

PLATFORM=tokocrypto
